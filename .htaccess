# ======================================================================
# SECURE HEADERS CONFIGURATION FOR HOSTINGER (APACHE/LITESPEED)
# ======================================================================
<IfModule mod_headers.c>
    # Content-Security-Policy (CSP)
    # Configura fontes externas (Google Fonts) e permite scripts e estilos locais
    Header set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data:; connect-src 'self'; frame-ancestors 'none'; base-uri 'self'; form-action 'self';"

    # Referrer-Policy
    # Controla o envio de informações de cabeçalho de referência
    Header set Referrer-Policy "no-referrer-when-downgrade"

    # X-Content-Type-Options
    # Impede ataques de sniffing de MIME-type
    Header set X-Content-Type-Options "nosniff"

    # X-Frame-Options
    # Protege contra clickjacking impedindo que o site seja colocado em iframes externos
    Header set X-Frame-Options "DENY"

    # X-XSS-Protection
    # Força a ativação de filtros XSS em navegadores legados
    Header set X-XSS-Protection "1; mode=block"

    # Permissions-Policy
    # Bloqueia recursos desnecessários do dispositivo (câmera, microfone, geolocalização)
    Header set Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=()"
</IfModule>

# ======================================================================
# PERFORMANCE & CACHING CONFIGURATION (Core Web Vitals)
# ======================================================================
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresDefault "access plus 1 month"

    # CSS & JS (1 Ano de cache por serem versionados/estáticos)
    ExpiresByType text/css "access plus 1 year"
    ExpiresByType application/javascript "access plus 1 year"
    ExpiresByType text/javascript "access plus 1 year"

    # Imagens, Favicon e Ícones SVG
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType image/x-icon "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"

    # Fontes
    ExpiresByType font/woff "access plus 1 year"
    ExpiresByType font/woff2 "access plus 1 year"
</IfModule>

# ======================================================================
# GZIP COMPRESSION (Redução de Tamanho de Arquivos)
# ======================================================================
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript
</IfModule>
